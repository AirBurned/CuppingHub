generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum Processing {
  WASHED
  NATURAL
  HONEY
  ANAEROBIC
  OTHER
}

enum RoastLevel {
  LIGHT
  MEDIUM
  DARK
}

enum LotStatus {
  ACTIVE
  ARCHIVED
}

enum BrewMethod {
  ESPRESSO
  V60
  AEROPRESS
  OTHER
}

enum RecipeType {
  OFFICIAL
  UNOFFICIAL
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  name         String
  role         Role         @default(MEMBER)
  evaluations     Evaluation[]
  recipes         Recipe[]
  comments        Comment[]
  cuppingSessions CuppingSession[]
  createdAt       DateTime     @default(now())
}

model Lot {
  id                String              @id @default(cuid())
  name              String
  country           String
  roaster           String
  farm              String?
  variety           String?
  processing        Processing
  customProcessing  String?
  roastLevel        RoastLevel
  roastDate         DateTime?
  altitude          String?
  descriptors       String?
  photoUrl          String?
  status            LotStatus           @default(ACTIVE)
  evaluations     Evaluation[]
  recipes         Recipe[]
  comments        Comment[]
  cuppingSessions CuppingSessionLot[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

enum CuppingStatus {
  PLANNED
  COMPLETED
}

model CuppingSession {
  id        String              @id @default(cuid())
  name      String
  date      DateTime
  notes     String?
  status    CuppingStatus       @default(PLANNED)
  createdBy User                @relation(fields: [createdById], references: [id])
  createdById String
  lots      CuppingSessionLot[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model CuppingSessionLot {
  id        String         @id @default(cuid())
  session   CuppingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  lot       Lot            @relation(fields: [lotId], references: [id])
  lotId     String
  order     Int            @default(0)

  @@unique([sessionId, lotId])
}

model Evaluation {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  lot             Lot      @relation(fields: [lotId], references: [id])
  lotId           String
  // Этап 1: Аромат смолотого зерна (1-10)
  aromaGround        Float?
  aromaGroundComment  String?
  // Этап 2: Аромат заваренного зерна (1-10)
  aromaBrewed        Float?
  aromaBrewedComment String?
  // Этап 3: Вкусовые характеристики (1-10)
  flavor      Float?
  aftertaste  Float?
  aftertasteDuration     Float?
  aftertastePleasantness Float?
  acidity     Float?
  body        Float?
  sweetness   Float?
  cleanCup    Float?
  overall     Float?
  // Итого (среднее вкусовых + оба аромата)
  totalScore  Float?
  descriptors String?
  comment     String?
  // Дефекты (1-10, отдельно от spider-graph)
  defectScore   Float?
  defectComment String?
  // Совместимость: старое поле aroma маппится на aromaGround
  aroma       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lotId])
}

model Recipe {
  id          String     @id @default(cuid())
  lot         Lot        @relation(fields: [lotId], references: [id])
  lotId       String
  brewMethod  BrewMethod
  recipeType  RecipeType @default(UNOFFICIAL)
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  dose        Float?
  yield       Float?
  waterAmount Float?
  ratio       String?
  grind       String?
  temperature Float?
  brewTime    String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  lot       Lot      @relation(fields: [lotId], references: [id])
  lotId     String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  text      String
  createdAt DateTime @default(now())
}
